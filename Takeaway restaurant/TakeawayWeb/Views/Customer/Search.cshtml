@{
    ViewData["Title"] = "Search";
    Layout = null;
    var results = ViewBag.Results as MenuItem[];
}

<!DOCTYPE html>
<html>
<head>
    <title>Search Menu</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #1a1a2e;
            color: #fff;
        }

        .navbar {
            background-color: #3498db;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .navbar h2 {
                margin: 0;
            }

            .navbar a {
                color: #fff;
                text-decoration: none;
                margin-left: 20px;
                font-size: 14px;
            }

                .navbar a:hover {
                    text-decoration: underline;
                }

        .container {
            max-width: 600px;
            margin: 30px auto;
            padding: 0 20px;
        }

        h1 {
            margin-bottom: 20px;
        }

        .search-form {
            margin-bottom: 25px;
        }

            .search-form input, .search-form select {
                padding: 10px;
                border: 1px solid #333;
                border-radius: 5px;
                background-color: #0f3460;
                color: #fff;
                font-size: 14px;
                margin-right: 5px;
            }

                .search-form input[type="text"] {
                    width: 250px;
                }

            .search-form button {
                padding: 10px 20px;
                background-color: #3498db;
                color: #fff;
                border: none;
                border-radius: 5px;
                cursor: pointer;
                font-size: 14px;
            }

                .search-form button:hover {
                    background-color: #2980b9;
                }

        .result {
            background-color: #16213e;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 10px;
        }

            .result h3 {
                color: #3498db;
            }

            .result .price {
                color: #2ecc71;
                font-weight: bold;
            }

        .no-results {
            color: #aaa;
        }
    </style>
</head>
<body>
    <div class="navbar">
        <h2>Takeaway Restaurant</h2>
        <div>
            <a href="/Customer/Index">Home</a>
            <a href="/Customer/Menu">Full Menu</a>
            <a href="/Customer/Search">Search</a>
            <a href="/Customer/Order">Place Order</a>
            <a href="/Customer/MyOrders">My Orders</a>
            <a href="/Customer/AI">AI Assistant</a>

            <a href="/Account/Logout">Logout</a>
        </div>
    </div>

    <div class="container">
        <h1>Search Menu</h1>

        <form method="get" asp-action="Search" class="search-form">
            <select name="searchType">
                <option value="name">By Name</option>
                <option value="id">By ID</option>
            </select>
            <input type="text" name="query" placeholder="Search..." value="@ViewBag.Query" />
            <button type="submit">Search</button>
        </form>

        @if (results != null)
        {
            if (results.Length == 0)
            {
                <p class="no-results">No items found. Try a different search.</p>
            }
            else
            {
                foreach (var item in results)
                {
                    <div class="result">
                        <h3>@item.Name</h3>
                        <span>@item.Category</span> —
                        <span class="price">£@item.Price.ToString("F2")</span>
                        <p>@item.Description</p>
                    </div>
                }
            }
        }
    </div>
</body>
</html>