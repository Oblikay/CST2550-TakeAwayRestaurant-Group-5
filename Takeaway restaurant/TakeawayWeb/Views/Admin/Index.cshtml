@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #1a1a2e;
            color: #fff;
        }

        .navbar {
            background-color: #e94560;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .navbar h2 {
                margin: 0;
            }

            .navbar a {
                color: #fff;
                text-decoration: none;
                margin-left: 20px;
                font-size: 14px;
            }

                .navbar a:hover {
                    text-decoration: underline;
                }

        .container {
            max-width: 1000px;
            margin: 30px auto;
            padding: 0 20px;
        }

        h1 {
            margin-bottom: 30px;
        }

        .cards {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        .card {
            background-color: #16213e;
            padding: 30px;
            border-radius: 10px;
            flex: 1;
            min-width: 200px;
            text-align: center;
            box-shadow: 0 0 10px rgba(0,0,0,0.3);
        }

            .card h3 {
                color: #e94560;
                font-size: 36px;
                margin-bottom: 10px;
            }

            .card p {
                color: #aaa;
            }

        .actions {
            margin-top: 30px;
        }

            .actions a {
                display: inline-block;
                padding: 15px 25px;
                background-color: #0f3460;
                color: #fff;
                text-decoration: none;
                border-radius: 5px;
                margin: 5px;
                font-size: 16px;
            }

                .actions a:hover {
                    background-color: #e94560;
                }
    </style>
</head>
<body>
    <div class="navbar">
        <h2>Admin Panel</h2>
        <div>
            <a href="/Admin/Menu">Menu</a>
            <a href="/Admin/AddItem">Add Item</a>
            <a href="/Admin/Orders">Orders</a>
            <a href="/Account/Logout">Logout</a>
        </div>
    </div>

    <div class="container">
        <h1>Dashboard</h1>

        <div class="cards">
            <div class="card">
                <h3>@ViewBag.MenuCount</h3>
                <p>Menu Items</p>
            </div>
            <div class="card">
                <h3>@ViewBag.OrderCount</h3>
                <p>Total Orders</p>
            </div>
        </div>

        <div class="actions">
            <a href="/Admin/Menu">View Full Menu</a>
            <a href="/Admin/AddItem">Add Menu Item</a>
            <a href="/Admin/Orders">View Orders</a>
        </div>
    </div>
</body>
</html>