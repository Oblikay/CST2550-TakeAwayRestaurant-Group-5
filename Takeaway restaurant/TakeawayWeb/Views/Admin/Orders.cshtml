@{
    ViewData["Title"] = "Manage Orders";
    Layout = null;
    var orders = ViewBag.Orders as Order[];
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin - Orders</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; background-color: #1a1a2e; color: #fff; }
        .navbar {
            background-color: #e94560;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .navbar h2 { margin: 0; }
        .navbar a { color: #fff; text-decoration: none; margin-left: 20px; font-size: 14px; }
        .navbar a:hover { text-decoration: underline; }
        .container { max-width: 1000px; margin: 30px auto; padding: 0 20px; }
        h1 { margin-bottom: 20px; }
        .order-card {
            background-color: #16213e;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 15px;
        }
        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        .order-header h3 { color: #e94560; }
        .status-form select {
            padding: 8px;
            background-color: #0f3460;
            color: #fff;
            border: 1px solid #333;
            border-radius: 3px;
        }
        .status-form button {
            padding: 8px 15px;
            background-color: #e94560;
            color: #fff;
            border: none;
            border-radius: 3px;
            cursor: pointer;
            margin-left: 5px;
        }
        .order-details { color: #aaa; font-size: 14px; }
        .order-items { margin-top: 10px; }
        .order-items span { display: block; color: #ccc; }
        .total { color: #2ecc71; font-weight: bold; margin-top: 10px; }
        .no-orders { color: #aaa; font-size: 16px; }
    </style>
</head>
<body>
    <div class="navbar">
        <h2>Admin Panel</h2>
        <div>
            <a href="/Admin/Index">Dashboard</a>
            <a href="/Admin/Menu">Menu</a>
            <a href="/Admin/AddItem">Add Item</a>
            <a href="/Admin/Orders">Orders</a>
            <a href="/Account/Logout">Logout</a>
        </div>
    </div>

    <div class="container">
        <h1>All Orders</h1>

        @if (orders == null || orders.Length == 0)
        {
            <p class="no-orders">No orders yet.</p>
        }
        else
        {
            @foreach (var order in orders)
            {
                <div class="order-card">
                    <div class="order-header">
                        <h3>Order #@order.OrderId</h3>
                        <form method="post" asp-action="UpdateStatus" class="status-form" style="display:flex; align-items:center;">
                            <input type="hidden" name="orderId" value="@order.OrderId" />
                            <select name="status">
                                @{
                                    string[] statuses = { "Pending", "Preparing", "Out for Delivery", "Completed" };
                                    foreach (var s in statuses)
                                    {
                                        if (order.Status == s)
                                        {
                                            <option value="@s" selected>@s</option>
                                        }
                                        else
                                        {
                                            <option value="@s">@s</option>
                                        }
                                    }
                                }
                            </select>
                            <button type="submit">Update</button>
                        </form>
                    </div>
                    <div class="order-details">
                        <p>Customer: @order.CustomerName | Phone: @order.CustomerPhone</p>
                        <p>Address: @order.CustomerAddress</p>
                        <p>Date: @order.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div class="order-items">
                        @for (int i = 0; i < order.ItemCount; i++)
                        {
                            <span>- @order.ItemNames[i] (£@order.ItemPrices[i].ToString("F2"))</span>
                        }
                    </div>
                    <p class="total">Total: £@order.TotalPrice.ToString("F2")</p>
                </div>
            }
        }
    </div>
</body>
</html>