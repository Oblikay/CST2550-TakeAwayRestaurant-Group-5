@{
    ViewData["Title"] = "Manage Menu";
    Layout = null;
    var items = ViewBag.Items as MenuItem[];
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin - Menu</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #1a1a2e;
            color: #fff;
        }

        .navbar {
            background-color: #e94560;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .navbar h2 {
                margin: 0;
            }

            .navbar a {
                color: #fff;
                text-decoration: none;
                margin-left: 20px;
                font-size: 14px;
            }

                .navbar a:hover {
                    text-decoration: underline;
                }

        .container {
            max-width: 1000px;
            margin: 30px auto;
            padding: 0 20px;
        }

        h1 {
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #333;
        }

        th {
            background-color: #0f3460;
            color: #e94560;
        }

        tr:hover {
            background-color: #16213e;
        }

        .btn-delete {
            background-color: #e94560;
            color: #fff;
            border: none;
            padding: 8px 15px;
            border-radius: 3px;
            cursor: pointer;
            text-decoration: none;
            font-size: 13px;
        }

            .btn-delete:hover {
                background-color: #c81e45;
            }

        .btn-add {
            display: inline-block;
            padding: 10px 20px;
            background-color: #2ecc71;
            color: #fff;
            text-decoration: none;
            border-radius: 5px;
            margin-bottom: 15px;
        }

            .btn-add:hover {
                background-color: #27ae60;
            }
    </style>
</head>
<body>
    <div class="navbar">
        <h2>Admin Panel</h2>
        <div>
            <a href="/Admin/Index">Dashboard</a>
            <a href="/Admin/Menu">Menu</a>
            <a href="/Admin/AddItem">Add Item</a>
            <a href="/Admin/Orders">Orders</a>
            <a href="/Account/Logout">Logout</a>
        </div>
    </div>

    <div class="container">
        <h1>Manage Menu</h1>
        <a href="/Admin/AddItem" class="btn-add">+ Add New Item</a>

        <table>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Description</th>
                <th>Action</th>
            </tr>
            @if (items != null)
            {
                @foreach (var item in items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Category</td>
                        <td>£@item.Price.ToString("F2")</td>
                        <td>@item.Description</td>
                        <td>
                         
                    </tr>
                }
            }
        </table>
    </div>
</body>
</html>