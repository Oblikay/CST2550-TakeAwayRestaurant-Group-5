@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Takeaway Restaurant - Login</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: Arial, sans-serif;
            background-color: #1a1a2e;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            color: #fff;
        }
        .login-box {
            background-color: #16213e;
            padding: 40px;
            border-radius: 10px;
            width: 400px;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            text-align: center;
        }
        .login-box h1 {
            margin-bottom: 10px;
            color: #e94560;
            font-size: 28px;
        }
        .login-box p {
            margin-bottom: 30px;
            color: #aaa;
        }
        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }
        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #ccc;
            font-size: 14px;
        }
        .form-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #333;
            border-radius: 5px;
            background-color: #0f3460;
            color: #fff;
            font-size: 16px;
        }
        .form-group input:focus {
            outline: none;
            border-color: #e94560;
        }
        .btn {
            width: 100%;
            padding: 12px;
            background-color: #e94560;
            color: #fff;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            cursor: pointer;
            margin-top: 10px;
        }
        .btn:hover { background-color: #c81e45; }
        .error {
            color: #e94560;
            margin-bottom: 15px;
            font-size: 14px;
        }
        .credentials {
            margin-top: 25px;
            padding: 15px;
            background-color: #0f3460;
            border-radius: 5px;
            font-size: 12px;
            color: #aaa;
            text-align: left;
        }
        .credentials strong { color: #e94560; }
    </style>
</head>
<body>
    <div class="login-box">
        <h1>Takeaway Restaurant</h1>
        <p>Please sign in to continue</p>

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

        <form method="post" asp-action="Login">
            <div class="form-group">
                <label>Username</label>
                <input type="text" name="username" required />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" required />
            </div>
            <button type="submit" class="btn">Sign In</button>
        </form>

        <div class="credentials">
            <strong>test Accounts:</strong><br />
            Admin: admin / admin123<br />
            Customer: customer / cust123
        </div>
    </div>
</body>
</html>